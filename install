#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if ! command -v stow &>/dev/null; then
  echo "stow is required but not installed."
  exit 1
fi

PACKAGES=(
  tmux
  ghostty
)

for pkg in "${PACKAGES[@]}"; do
  stow -d "$DOTFILES_DIR" -t "$HOME" "$pkg"
  echo "  ✓ $pkg"
done
